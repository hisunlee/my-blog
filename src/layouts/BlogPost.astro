---
// src/layouts/BlogPost.astro  ← 기존 파일 전체를 이 내용으로 덮어쓰기
// 주의: 이 레이아웃이 유일한 최상위 레이아웃이다.
// BaseHead / Header / Footer 를 감싸는 다른 레이아웃을 추가로 import 하지 말 것.
// 이것이 Recent Posts 가 두 번 나오던 원인이다.
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const { title, description, pubDate, tags = [] } = Astro.props;

const recent = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const fmt = (d) =>
  d instanceof Date ? d.toISOString().slice(0, 10) : String(d).slice(0, 10);
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Sun Lee</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header />

    <main class="wrap">
      <article class="content">
        <h1>{title}</h1>
        <p class="meta">
          {fmt(pubDate)}
          {tags.length > 0 && <span> · {tags.join(" · ")}</span>}
        </p>
        <slot />
      </article>

      <aside class="sidebar">
        <h2>Recent Posts</h2>
        <ul>
          {recent.map((p) => (
            <li>
              <a href={`/blog/${p.slug}/`}>{p.data.title}</a>
              <time>{fmt(p.data.pubDate)}</time>
            </li>
          ))}
        </ul>
      </aside>
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  :root { --text: #1a1a1a; --muted: #777; }
  body {
    margin: 0;
    color: var(--text);
    background: #fff;
    line-height: 1.75;
    font-family: "Pretendard", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) { .wrap { grid-template-columns: 1fr; } }

  .content { min-width: 0; }
  .content h1 {
    font-family: Georgia, serif;
    font-size: 2.1rem;
    line-height: 1.3;
    margin: 0 0 0.5rem;
  }
  .content .meta { color: var(--muted); font-size: 0.85rem; margin: 0 0 2rem; }
  .content h2 { font-family: Georgia, serif; margin-top: 3rem; }
  .content img { max-width: 100%; }

  .hero-image { margin: 0 0 2rem; }
  .hero-image img { width: 100%; border-radius: 8px; display: block; }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.9rem;
    margin: 2rem 0;
  }
  .photo-grid figure { margin: 0; }
  .photo-grid img {
    width: 100%;
    height: 185px;
    object-fit: cover;
    border-radius: 6px;
    display: block;
  }
  .photo-grid figcaption,
  .hero-image figcaption {
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 0.35rem;
  }

  /* YouTube: 면적 1/4 */
  .video-embed {
    position: relative;
    width: 50%;
    padding-bottom: 28.125%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
    margin: 1.25rem 0;
  }
  .video-embed iframe {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%; border: 0;
  }
  @media (max-width: 640px) {
    .video-embed { width: 100%; padding-bottom: 56.25%; }
  }

  .sidebar {
    position: sticky;
    top: 90px;
    border-left: 1px solid #eee;
    padding-left: 1.75rem;
  }
  .sidebar h2 {
    font-family: Georgia, serif;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 1rem;
  }
  .sidebar ul { list-style: none; margin: 0; padding: 0; }
  .sidebar li { margin-bottom: 1.1rem; }
  .sidebar a {
    display: block;
    color: #111;
    text-decoration: none;
    font-size: 0.92rem;
    line-height: 1.45;
  }
  .sidebar a:hover { text-decoration: underline; }
  .sidebar time { font-size: 0.75rem; color: var(--muted); }
  @media (max-width: 900px) {
    .sidebar {
      position: static;
      border-left: 0;
      padding-left: 0;
      border-top: 1px solid #eee;
      padding-top: 2rem;
    }
  }
</style>
