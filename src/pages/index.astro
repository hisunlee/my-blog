---
// src/pages/index.astro
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recent = posts.slice(0, 6);
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sun Lee</title>
  </head>
  <body>
    <Header />

    <main class="wrap">
      <section class="content">
        <h1 class="hello">Hello</h1>
        <!-- Hello 아래 소개 문단 제거됨 -->

        <ul class="post-list">
          {posts.map((p) => (
            <li>
              <a href={`/blog/${p.slug}/`}>
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
                <time>{p.data.pubDate.toISOString().slice(0, 10)}</time>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <aside class="sidebar">
        <h2>Recent Posts</h2>
        <ul>
          {recent.map((p) => (
            <li>
              <a href={`/blog/${p.slug}/`}>{p.data.title}</a>
              <time>{p.data.pubDate.toISOString().slice(0, 10)}</time>
            </li>
          ))}
        </ul>
      </aside>
    </main>

    <Footer />
  </body>
</html>

<style>
  .wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) { .wrap { grid-template-columns: 1fr; } }

  .hello {
    font-family: Georgia, serif;
    font-size: 3rem;
    margin: 0 0 2.5rem;
  }
  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-list li { border-bottom: 1px solid #eee; padding: 1.4rem 0; }
  .post-list a { text-decoration: none; color: #111; }
  .post-list h3 { font-family: Georgia, serif; margin: 0 0 0.4rem; font-size: 1.3rem; }
  .post-list p { margin: 0 0 0.4rem; color: #555; font-size: 0.92rem; }
  .post-list time { font-size: 0.75rem; color: #999; }
</style>
