---
// src/components/Header.astro  ← 기존 파일 전체를 이 내용으로 덮어쓰기
const nav = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="inner">
    <a href="/" class="brand">Sun Lee</a>
    <nav>
      {nav.map((i) => (
        <a href={i.href} class={path === i.href || (i.href !== "/" && path.startsWith(i.href)) ? "active" : ""}>
          {i.label}
        </a>
      ))}
    </nav>
  </div>
  {/* Mastodon / Twitter / GitHub 소셜 링크 전부 제거됨 */}
</header>

<style>
  .site-header {
    border-bottom: 1px solid #e5e5e5;
    background: #fff;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #111;
    text-decoration: none;
  }
  nav { display: flex; gap: 1.75rem; }
  nav a {
    color: #444;
    text-decoration: none;
    font-size: 0.95rem;
    padding-bottom: 2px;
  }
  nav a:hover { color: #000; }
  nav a.active { color: #000; border-bottom: 2px solid #111; }
  @media (max-width: 640px) {
    .inner { flex-direction: column; gap: 0.75rem; }
  }
</style>
